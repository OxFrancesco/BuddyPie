{
  "name": "buddypie",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "bunx convex dev --once && concurrently -r \"bun run dev:web\" \"bun run dev:convex\"",
    "dev:web": "vite dev --configLoader native",
    "dev:convex": "bunx convex dev",
    "build": "vite build --configLoader native && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "format": "prettier --write .",
    "lint": "tsc && eslint .  --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "register:agents": "bun run scripts/register-erc8004.ts",
    "register:agents:dry": "bun run scripts/register-erc8004.ts --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@clerk/backend": "^3.2.0",
    "@clerk/tanstack-react-start": "^0.29.8",
    "@convex-dev/react-query": "0.1.0",
    "@daytonaio/sdk": "^0.150.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.166.7",
    "@tanstack/react-router-devtools": "^1.166.7",
    "@tanstack/react-router-with-query": "^1.130.17",
    "@tanstack/react-start": "^1.166.8",
    "@x402/core": "^2.6.0",
    "@x402/evm": "^2.6.0",
    "@x402/express": "^2.6.0",
    "@x402/fetch": "^2.6.0",
    "agent0-sdk": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.33.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redaxios": "^0.5.1",
    "shadcn": "^4.0.6",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "viem": "^2.47.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "~9.2.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
